# Copy this file to .env and adjust values.
# Keys map to Settings fields in config.py (case-insensitive).

# REQUIRED -- the app refuses to start with the default secret.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=medgemma:4b-it-q8_0
EMBED_MODEL=nomic-embed-text

# Segmentation device: "gpu" or "cpu"
DEVICE=gpu

# RAG
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Auth
AUTH_TOKEN_EXPIRE_HOURS=24

# App
DEBUG=false

# Set true when serving over HTTPS so the auth cookie is Secure
COOKIE_SECURE=false
